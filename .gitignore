# ============================================================
# Python estándar
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ============================================================
# Entornos virtuales
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# SECRETOS — NUNCA commitear
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ============================================================
# Datos locales del bot
# ============================================================
data/raw/*
data/processed/*
data/backtests/*
data/storage/*
data/chart_snapshots/*
data/*.db
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/backtests/.gitkeep
!data/storage/.gitkeep

# ============================================================
# Logs y reportes
# ============================================================
*.log
*.out.txt
logs/*
!logs/.gitkeep
reports/*
!reports/.gitkeep

# ============================================================
# Notebooks — solo checkpoints
# ============================================================
notebooks/.ipynb_checkpoints/

# ============================================================
# Herramientas / IDEs
# ============================================================
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp

# ============================================================
# Testing / Coverage
# ============================================================
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.mypy_cache/
.ruff_cache/

# ============================================================
# Docker
# ============================================================
docker-data/

# ============================================================
# Sistema SDD / outputs generados
# ============================================================
.ai/skills/*.tmp

# ============================================================
# Workstream transient commit bodies (`git commit -F <body>`).
# Pino explícito para que `git add -A` accidental nunca trackee
# estos ficheros. CF `.github/workflows/ci.yml` step
# `Forbid tracked transient files` que grep-checka el nombre
# contra `git ls-files` y rompe el build si filtra alguno.
# `*.out.txt` cubría implicitamente algunos pero NO todos
# (`commit_msg.txt`, `commit_msg_cluster1.txt`, etc.) — este
# patrón fijo la convención permanente.
# ============================================================
commit_msg*.txt
