# ============================================================
# Python estándar
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ============================================================
# Entornos virtuales
# ============================================================
.venv/
venv/
env/
ENV/

# ============================================================
# SECRETOS — NUNCA commitear
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# ============================================================
# Datos locales del bot
# ============================================================
data/raw/*
data/processed/*
data/backtests/*
data/storage/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/backtests/.gitkeep
!data/storage/.gitkeep

# ============================================================
# Logs y reportes
# ============================================================
logs/*
!logs/.gitkeep
reports/*
!reports/.gitkeep

# ============================================================
# Notebooks — solo checkpoints
# ============================================================
notebooks/.ipynb_checkpoints/

# ============================================================
# Herramientas / IDEs
# ============================================================
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp

# ============================================================
# Testing / Coverage
# ============================================================
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.tox/
.mypy_cache/
.ruff_cache/

# ============================================================
# Docker
# ============================================================
docker-data/

# ============================================================
# Sistema SDD / outputs generados
# ============================================================
.ai/skills/*.tmp
