# ============================================================
# crypto-scalping-agentic-bot — .env.example
# Copia este archivo a .env y rellena los valores necesarios.
# NUNCA commitees el archivo .env con valores reales.
# ============================================================

# ----------------------------
# Modo de ejecución
# ----------------------------
# Valores permitidos: research | backtest | paper | shadow-live | live
# Por seguridad, "live" requiere además LIVE_TRADING_ENABLED=true
# y I_UNDERSTAND_THE_RISKS=true. Por defecto se fuerza a "paper".
TRADING_MODE=paper

# ----------------------------
# Live trading gates (ambos requeridos para desbloquear live)
# ----------------------------
LIVE_TRADING_ENABLED=false
I_UNDERSTAND_THE_RISKS=false

# ----------------------------
# Exchange (CCXT)
# ----------------------------
# Ejemplos: binance, kraken, coinbasepro, bitfinex, bybit, okx, ...
EXCHANGE_ID=binance
# IMPORTANTE: NO usar valores que parezcan claves reales.
# Reemplazar por tus claves de TESTNET antes de cualquier ejecución.
EXCHANGE_API_KEY=changeme-paste-testnet-key
EXCHANGE_API_SECRET=changeme-paste-testnet-secret
EXCHANGE_PASSWORD=changeme-paste-testnet-password   # solo algunos exchanges (OKX, Coinbase, ...)
EXCHANGE_SANDBOX=true                                # true = usar testnet/sandbox del exchange

# ----------------------------
# Capital de paper trading
# ----------------------------
PAPER_INITIAL_BALANCE_USDT=10000

# ----------------------------
# Observabilidad
# ----------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json                                   # json | text
LOG_TO_FILE=true
LOG_FILE_PATH=logs/app.log

# ----------------------------
# Persistencia
# ----------------------------
DATABASE_URL=sqlite:///data/storage/bot.db

# ----------------------------
# Scheduler
# ----------------------------
SCHEDULER_TIMEZONE=UTC
ACTIVE_HOURS_START=00:00
ACTIVE_HOURS_END=23:59

# ----------------------------
# Tests / CI
# ----------------------------
PYTEST_MARKERS=unit,integration,regression
TESTNET_REQUIRED_FOR_LIVE_GATES=true
